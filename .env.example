# Copy to .env (local) and set these in the Vercel project settings (production).

# Postgres connection string — Vercel Postgres, Neon, Supabase, etc.
# On serverless, use the POOLED connection string.
DATABASE_URL="postgresql://user:password@host:5432/penguinlabs?sslmode=require"

# Secret used to sign the session cookie (JWT). Generate a long random value, e.g.
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
